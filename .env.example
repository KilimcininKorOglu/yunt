# Yunt Mail Server - Environment Configuration
#
# Copy this file to .env and customize the values for your environment.
# All settings are optional - defaults are shown below.
#
# Usage:
#   cp .env.example .env
#   docker-compose up -d

# =============================================================================
# Build Settings (used during docker build)
# =============================================================================

# Version tag for the built image
YUNT_VERSION=dev

# Git commit hash
YUNT_COMMIT=unknown

# Build timestamp
YUNT_BUILD_DATE=unknown

# =============================================================================
# Port Mappings
# =============================================================================

# SMTP server port (host:container is YUNT_SMTP_PORT:1025)
YUNT_SMTP_PORT=1025

# IMAP server port (host:container is YUNT_IMAP_PORT:1143)
YUNT_IMAP_PORT=1143

# Web UI and API port (host:container is YUNT_API_PORT:8025)
YUNT_API_PORT=8025

# =============================================================================
# Server Settings
# =============================================================================

# Server hostname used in SMTP HELO/EHLO
YUNT_SERVER_NAME=localhost

# Primary mail domain
YUNT_SERVER_DOMAIN=localhost

# =============================================================================
# Database Configuration
# =============================================================================

# Database driver: sqlite, postgres, mysql, mongodb
YUNT_DATABASE_DRIVER=sqlite

# Database connection string
# SQLite: file path (default: /var/lib/yunt/yunt.db)
# PostgreSQL: host=localhost port=5432 user=yunt password=secret dbname=yunt sslmode=disable
# MySQL: user:password@tcp(localhost:3306)/yunt?charset=utf8mb4&parseTime=True
# MongoDB: mongodb://localhost:27017/yunt
YUNT_DATABASE_DSN=/var/lib/yunt/yunt.db

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: debug, info, warn, error
YUNT_LOGGING_LEVEL=info

# Log format: json, text
YUNT_LOGGING_FORMAT=json

# Log output: stdout, stderr, file
YUNT_LOGGING_OUTPUT=stdout

# =============================================================================
# Authentication Settings
# =============================================================================

# JWT secret key for token signing
# IMPORTANT: Set a secure random value in production!
# Generate with: openssl rand -hex 32
YUNT_AUTH_JWTSECRET=

# =============================================================================
# Admin User Settings
# =============================================================================

# Admin username
YUNT_ADMIN_USERNAME=admin

# Admin password
# IMPORTANT: Set a secure password in production!
YUNT_ADMIN_PASSWORD=

# Admin email address
YUNT_ADMIN_EMAIL=admin@localhost

# =============================================================================
# SMTP Settings
# =============================================================================

# Require authentication for sending mail
YUNT_SMTP_AUTHREQUIRED=false

# Allow relaying to external domains
YUNT_SMTP_ALLOWRELAY=false

# =============================================================================
# API Settings
# =============================================================================

# Rate limit: requests per minute per IP
YUNT_API_RATELIMIT=100
