# Yunt Mail Server - PostgreSQL Environment Variables
#
# This file contains environment variables for the PostgreSQL database container
# when using the 'postgres' Docker Compose profile.
#
# Usage:
#   docker-compose --profile postgres up -d
#
# IMPORTANT: Change the default passwords in production environments!
# Generate secure passwords with: openssl rand -base64 32

# =============================================================================
# PostgreSQL Container Configuration
# =============================================================================

# Database superuser password (for maintenance operations)
# Used by the postgres container for initial setup
POSTGRES_USER=yunt
POSTGRES_PASSWORD=yunt_password
POSTGRES_DB=yunt

# =============================================================================
# Yunt Database Connection Settings
# =============================================================================

# Database driver (postgres for PostgreSQL)
YUNT_DATABASE_DRIVER=postgres

# PostgreSQL connection settings (used by Yunt container)
YUNT_DATABASE_HOST=postgres
YUNT_DATABASE_PORT=5432
YUNT_DATABASE_NAME=yunt
YUNT_DATABASE_USERNAME=yunt
YUNT_DATABASE_PASSWORD=yunt_password

# SSL Mode for PostgreSQL connections
# Options: disable, require, verify-ca, verify-full
# Use 'disable' for local development, 'require' or higher for production
YUNT_DATABASE_SSLMODE=disable

# Connection pool settings
YUNT_DATABASE_MAXOPENCONNS=25
YUNT_DATABASE_MAXIDLECONNS=10
YUNT_DATABASE_CONNMAXLIFETIME=30m
YUNT_DATABASE_CONNMAXIDLETIME=5m

# Automatically run database migrations on startup
YUNT_DATABASE_AUTOMIGRATE=true
