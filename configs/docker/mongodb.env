# =============================================================================
# MongoDB Configuration for Yunt Mail Server
# =============================================================================
# This file contains environment variables for MongoDB database configuration.
# Used with: docker-compose --profile mongodb up -d
#
# Copy and modify values as needed for your environment.
# =============================================================================

# MongoDB Connection Settings
MONGO_INITDB_ROOT_USERNAME=yunt
MONGO_INITDB_ROOT_PASSWORD=yunt_secret
MONGO_INITDB_DATABASE=yunt

# Yunt Database Settings
# The DSN follows MongoDB connection string format:
# mongodb://[username:password@]host[:port]/database[?options]
YUNT_DATABASE_DRIVER=mongodb
YUNT_DATABASE_DSN=mongodb://yunt:yunt_secret@mongodb:27017/yunt?authSource=admin

# Database name (extracted from DSN if not specified)
YUNT_DATABASE_NAME=yunt

# Connection pool settings
YUNT_DATABASE_MAXOPENCONNS=100
YUNT_DATABASE_MAXIDLECONNS=5
YUNT_DATABASE_CONNMAXIDLETIME=30m

# Auto-migrate (create indexes) on startup
YUNT_DATABASE_AUTOMIGRATE=true
