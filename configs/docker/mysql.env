# =============================================================================
# Yunt Mail Server - MySQL Docker Environment Configuration
# =============================================================================
# This file contains environment variables for running Yunt with MySQL.
#
# Usage:
#   1. Copy this file to .env in the project root
#   2. Modify values as needed
#   3. Start with: docker-compose --profile mysql up -d
#
# Security Note:
#   In production, use strong passwords and consider using Docker secrets.
# =============================================================================

# =============================================================================
# MySQL Database Configuration
# =============================================================================

# Root password for MySQL server (required)
# IMPORTANT: Change this in production!
MYSQL_ROOT_PASSWORD=root_secret

# Database name for Yunt
MYSQL_DATABASE=yunt

# Database user for Yunt application
MYSQL_USER=yunt

# Password for Yunt database user
# IMPORTANT: Change this in production!
MYSQL_PASSWORD=yunt_password

# =============================================================================
# MySQL Server Settings
# =============================================================================
# These settings are configured via command arguments in docker-compose.yml:
#   --character-set-server=utf8mb4
#   --collation-server=utf8mb4_unicode_ci
#   --default-authentication-plugin=mysql_native_password
#
# UTF8MB4 encoding is used to support full Unicode including emoji.
# =============================================================================

# =============================================================================
# Yunt Application Configuration
# =============================================================================

# Database driver (mysql for MySQL)
YUNT_DATABASE_DRIVER=mysql

# MySQL host (container name in docker-compose)
YUNT_DATABASE_HOST=mysql

# MySQL port
YUNT_DATABASE_PORT=3306

# Database name (should match MYSQL_DATABASE)
YUNT_DATABASE_NAME=yunt

# Database username (should match MYSQL_USER)
YUNT_DATABASE_USERNAME=yunt

# Database password (should match MYSQL_PASSWORD)
YUNT_DATABASE_PASSWORD=yunt_password

# Automatically run migrations on startup
YUNT_DATABASE_AUTOMIGRATE=true

# =============================================================================
# Connection Pool Settings (optional)
# =============================================================================

# Maximum open connections to the database
# YUNT_DATABASE_MAXOPENCONNS=25

# Maximum idle connections in the pool
# YUNT_DATABASE_MAXIDLECONNS=10

# Maximum lifetime of a connection (duration string, e.g., "5m")
# YUNT_DATABASE_CONNMAXLIFETIME=5m

# Maximum idle time of a connection (duration string, e.g., "5m")
# YUNT_DATABASE_CONNMAXIDLETIME=5m

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: debug, info, warn, error
YUNT_LOGGING_LEVEL=info

# Log format: json, text
YUNT_LOGGING_FORMAT=json

# Log output: stdout, stderr, file path
YUNT_LOGGING_OUTPUT=stdout

# =============================================================================
# Server Port Configuration
# =============================================================================

# SMTP server port
YUNT_SMTP_PORT=1025

# IMAP server port
YUNT_IMAP_PORT=1143

# Web UI and API port
YUNT_API_PORT=8025

# =============================================================================
# Authentication Settings
# =============================================================================

# JWT secret key for token signing
# IMPORTANT: Set a secure random value in production!
# Generate with: openssl rand -hex 32
# YUNT_AUTH_JWTSECRET=your-secure-secret-here

# Admin username
YUNT_ADMIN_USERNAME=admin

# Admin password
# IMPORTANT: Change this in production!
# YUNT_ADMIN_PASSWORD=your-secure-password-here

# Admin email address
YUNT_ADMIN_EMAIL=admin@localhost
